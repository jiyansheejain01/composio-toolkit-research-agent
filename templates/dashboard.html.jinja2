<!-- ============ EMBEDDED DATA ============ -->
<script type="application/json" id="apps-data">{{ apps | tojson }}</script>
<script type="application/json" id="insights-data">{{ insights | tojson }}</script>

<script>
const APPS = JSON.parse(document.getElementById('apps-data').textContent);
const INSIGHTS = JSON.parse(document.getElementById('insights-data').textContent);

// ---------- populate filters ----------
const categories = [...new Set(APPS.map(a => a.category))].sort();
const catSel = document.getElementById('categoryFilter');
categories.forEach(c => { const o = document.createElement('option'); o.value = c; o.textContent = c; catSel.appendChild(o); });

const selfServeModels = [...new Set(APPS.map(a => a.self_serve))].sort();
const ssSel = document.getElementById('selfServeFilter');
const ssLabels = {
  open: 'Open (no gate)', freemium_signup: 'Freemium signup', trial_required: 'Trial required',
  admin_approval_required: 'Admin approval required', paid_plan_required: 'Paid plan required',
  partnership_required: 'Partnership required', contact_sales_only: 'Contact sales only', gated_unclear: 'Gated / unclear'
};
selfServeModels.forEach(s => { const o = document.createElement('option'); o.value = s; o.textContent = ssLabels[s] || s; ssSel.appendChild(o); });

// ---------- badge helpers ----------
function buildBadge(level) {
  const map = { Easy: 'bg-good/10 text-good border-good/30', Medium: 'bg-warn/10 text-warn border-warn/30',
                Hard: 'bg-bad/10 text-bad border-bad/30', Impossible: 'bg-bad/20 text-bad border-bad/50' };
  return `<span class="badge border ${map[level] || ''}">${level}</span>`;
}
function statusBadge(status) {
  const map = { human_verified: ['bg-teal/10 text-teal border-teal/30', 'HUMAN-VERIFIED'],
                agent_verified: ['bg-indigo/10 text-indigo border-indigo/30', 'AGENT-VERIFIED'],
                flagged: ['bg-warn/10 text-warn border-warn/30', 'FLAGGED'],
                unverified: ['bg-surface2 text-muted border-line', 'UNVERIFIED'] };
  const [cls, label] = map[status] || ['bg-surface2 text-muted border-line', status];
  return `<span class="badge border ${cls}">${label}</span>`;
}
function confBadge(score) {
  let cls = 'bg-good/10 text-good border-good/30';
  if (score < 70) cls = 'bg-warn/10 text-warn border-warn/30';
  if (score < 40) cls = 'bg-bad/10 text-bad border-bad/30';
  return `<span class="badge border ${cls}">${score}</span>`;
}
function mcpBadge(mcp) {
  if (mcp.official) return `<span class="badge bg-teal/10 text-teal border border-teal/30">OFFICIAL</span>`;
  if (mcp.community) return `<span class="badge bg-indigo/10 text-indigo border border-indigo/30">COMMUNITY</span>`;
  return `<span class="badge bg-surface2 text-muted border border-line">NONE</span>`;
}

// ---------- render table ----------
const tbody = document.getElementById('tableBody');
function renderTable(rows) {
  tbody.innerHTML = '';
  document.getElementById('resultCount').textContent = `${rows.length} of ${APPS.length} apps`;
  rows.forEach((a) => {
    const tr = document.createElement('tr');
    tr.className = 'border-t border-line hover:bg-surface2 cursor-pointer';
    tr.innerHTML = `
      <td class="px-4 py-3 font-medium">${a.name}</td>
      <td class="px-4 py-3 text-muted text-xs whitespace-nowrap">${a.category}</td>
      <td class="px-4 py-3 text-xs text-muted">${a.auth.join(', ')}</td>
      <td class="px-4 py-3 text-xs text-muted whitespace-nowrap">${ssLabels[a.self_serve] || a.self_serve}</td>
      <td class="px-4 py-3">${mcpBadge(a.mcp)}</td>
      <td class="px-4 py-3">${buildBadge(a.buildability)}</td>
      <td class="px-4 py-3">${confBadge(a.confidence)}</td>
      <td class="px-4 py-3">${statusBadge(a.verification_status)}</td>
    `;
    const detail = document.createElement('tr');
    detail.className = 'table-row-expand border-t border-line bg-surface2/50';
    detail.innerHTML = `
      <td colspan="8" class="px-4 py-4 text-xs text-muted">
        <p class="mb-2"><span class="text-ink font-medium">${a.description}</span></p>
        <p class="mb-2">${a.self_serve_detail || ''}</p>
        ${a.blocker ? `<p class="mb-2 text-warn">Blocker: ${a.blocker}</p>` : ''}
        <p class="mb-2">API surface: REST=${a.api_surface.rest} · GraphQL=${a.api_surface.graphql} · Webhooks=${a.api_surface.webhooks} · Breadth=${a.api_surface.breadth || 'n/a'} · Rate limits=${a.api_surface.rate_limits || 'n/a'}</p>
        <p class="mb-2">MCP notes: ${a.mcp.notes || 'n/a'}</p>
        ${a.notes ? `<p class="mb-2 italic">${a.notes}</p>` : ''}
        <a href="${a.evidence}" target="_blank" rel="noopener" class="evidence-link text-teal underline">${a.evidence} ↗</a>
      </td>`;
    tr.addEventListener('click', () => detail.classList.toggle('open'));
    tbody.appendChild(tr);
    tbody.appendChild(detail);
  });
}
renderTable(APPS);

// ---------- filtering ----------
function getFiltered() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const cat = catSel.value, ss = ssSel.value, build = document.getElementById('buildFilter').value;
  const verif = document.getElementById('verificationFilter').value;
  const conf = document.getElementById('confidenceFilter').value;
  return APPS.filter(a => {
    const matchesQ = !q || a.name.toLowerCase().includes(q) || a.category.toLowerCase().includes(q) ||
      (a.blocker || '').toLowerCase().includes(q) || a.description.toLowerCase().includes(q);
    const matchesCat = !cat || a.category === cat;
    const matchesSS = !ss || a.self_serve === ss;
    const matchesBuild = !build || a.buildability === build;
    const matchesVerif = !verif || a.verification_status === verif;
    const matchesConf = !conf || (conf === 'high' && a.confidence >= 70) ||
      (conf === 'medium' && a.confidence >= 40 && a.confidence < 70) || (conf === 'low' && a.confidence < 40);
    return matchesQ && matchesCat && matchesSS && matchesBuild && matchesVerif && matchesConf;
  });
}

let sortKey = null, sortDir = 1;
function applyFilters() {
  let rows = getFiltered();
  if (sortKey) {
    rows = [...rows].sort((a, b) => {
      const av = a[sortKey], bv = b[sortKey];
      if (typeof av === 'number') return (av - bv) * sortDir;
      return String(av).localeCompare(String(bv)) * sortDir;
    });
  }
  renderTable(rows);
}
['searchInput'].forEach(id => document.getElementById(id).addEventListener('input', applyFilters));
['categoryFilter','selfServeFilter','buildFilter','verificationFilter','confidenceFilter'].forEach(id =>
  document.getElementById(id).addEventListener('change', applyFilters));

document.querySelectorAll('th.sortable').forEach(th => {
  th.addEventListener('click', () => {
    const key = th.dataset.key;
    if (sortKey === key) { sortDir *= -1; } else { sortKey = key; sortDir = 1; }
    document.querySelectorAll('th.sortable').forEach(t => t.classList.remove('active'));
    th.classList.add('active');
    th.querySelector('.arrow').textContent = sortDir === 1 ? '↑' : '↓';
    applyFilters();
  });
});

