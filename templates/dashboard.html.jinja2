const effortLabelsFull = Object.keys(INSIGHTS.auth_effort_counts);
const effortValues = Object.values(INSIGHTS.auth_effort_counts);
// Full effort-tier descriptions are long (e.g. "Higher (OAuth2 app registration +
// consent flow + token refresh)") -- unreadable as chart tick labels or a donut
// legend. Show a short tier name on the axis; keep the full description as the
// tooltip, so the chart stays scannable without losing the explanatory detail.
const effortShortLabels = effortLabelsFull.map(l => l.split(' (')[0]);
new Chart(document.getElementById('authEffortChart'), {
  type: 'bar',
  data: { labels: effortShortLabels, datasets: [{ label: 'Apps', data: effortValues,
    backgroundColor: ['#FB7185','#4FD1C5','#FBBF24','#8993AC'], borderRadius: 4 }] },
  options: { indexAxis: 'y', plugins: {
      legend: { display: false },
      title: { display: true, text: 'Implementation effort by auth type', color: '#E7ECF6' },
      tooltip: { callbacks: { title: (items) => effortLabelsFull[items[0].dataIndex] } }
    },
    scales: { x: { grid: { color: '#232D42' } }, y: { grid: { display: false } } } }
});
