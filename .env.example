# Required only for LIVE research mode (scripts/run_research.py).
# Without this set, the pipeline runs in OFFLINE mode using the verified
# output already checked into pipeline/seed_dataset.py, and every other
# stage (verification, pattern analysis, dashboard) still runs end-to-end.
OPENAI_API_KEY=

# Optional: if you wire in Firecrawl for docs the model's built-in web_search
# tool can't reach (JS-rendered pages, PDFs, login-walled portals).
FIRECRAWL_API_KEY=

# Required only for the Composio catalog cross-check (scripts/run_composio_crosscheck.py).
# Without this set, that stage writes NOT_CHECKED_OFFLINE_MODE for all rows instead
# of guessing which apps are already Composio toolkits. Get a key at app.composio.dev.
COMPOSIO_API_KEY=
